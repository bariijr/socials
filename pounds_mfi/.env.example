# ─────────────────────────────────────────────
#  POUNDS MICROFINANCE LTD — Environment Config
# ─────────────────────────────────────────────

# App
NODE_ENV=production
APP_NAME="Pounds Microfinance Ltd"
APP_PORT=3000
APP_URL=https://mfi.yourdomain.com
FRONTEND_URL=https://mfi.yourdomain.com
API_URL=https://mfi.yourdomain.com/api

# Security
JWT_SECRET=change-this-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_INACTIVITY_TIMEOUT=900
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=pounds_user
DB_PASSWORD=StrongPassword123!
DB_NAME=pounds_mfi
DB_SYNC=false
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisPassword123!
REDIS_DB=0

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_MAX_FILE_SIZE=10485760
# S3 (future)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM="Pounds MFI <noreply@yourdomain.com>"

# SMS (Africa's Talking or Twilio)
SMS_PROVIDER=africastalking
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=POUNDS
# Twilio fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp (360dialog or Meta Cloud API)
WHATSAPP_PROVIDER=360dialog
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_FROM_NUMBER=254700000000

# OCR
TESSERACT_LANG=eng
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_EMAIL_RECIPIENTS=admin@yourdomain.com,backup@yourdomain.com
SFTP_HOST=backup.yourdomain.com
SFTP_PORT=22
SFTP_USER=backup_user
SFTP_KEY_PATH=/app/ssh/backup_key
SFTP_REMOTE_PATH=/backups/pounds_mfi

# Branding
BRAND_NAME="Pounds Microfinance Ltd"
BRAND_TAGLINE="Financial Empowerment for All"
BRAND_PRIMARY_COLOR=#1E40AF
BRAND_SECONDARY_COLOR=#059669
BRAND_LOGO_URL=/assets/logo.png
BRAND_FAVICON_URL=/assets/favicon.ico
BRAND_FOOTER_TEXT="© 2024 Pounds Microfinance Ltd. All rights reserved."
BRAND_SUPPORT_EMAIL=support@yourdomain.com
BRAND_SUPPORT_PHONE=+254700000000

# Financial
DEFAULT_PROCESSING_FEE_PERCENT=5
DEFAULT_PENALTY_PERCENT=5
DEFAULT_PENALTY_FREQUENCY=weekly

# Encryption
ENCRYPTION_KEY=32-char-hex-encryption-key-here!
