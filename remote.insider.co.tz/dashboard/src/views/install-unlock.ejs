<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/insider.css?v=1.0.1">
  <link rel="icon" href="<%= faviconUrl %>" type="image/x-icon">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0d1117;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font, 'Inter', 'Segoe UI', sans-serif);
      color: #c9d1d9;
    }
    .gate { width: min(420px, 94vw); }

    .gate-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      padding-left: 2px;
    }
    .gate-logo { width: 38px; height: 38px; border-radius: 9px; object-fit: contain; background: #0A1931; }
    .gate-appname { font-size: 1rem; font-weight: 700; color: #c9d1d9; }
    .gate-company { font-size: 0.72rem; color: rgba(255,255,255,0.35); }

    .gate-card {
      background: #161b22;
      border: 1px solid #30363d;
      border-top: 3px solid #D01000;
      border-radius: 12px;
      padding: 36px 32px 32px;
    }

    .gate-icon {
      width: 52px; height: 52px;
      background: rgba(208,16,0,0.1);
      border: 1.5px solid rgba(208,16,0,0.3);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      color: #D01000;
      margin-bottom: 20px;
    }

    .gate-title {
      font-size: 1.25rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 6px;
    }
    .gate-sub {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
      margin-bottom: 26px;
    }

    .gate-error {
      margin-bottom: 16px;
      padding: 10px 14px;
      background: rgba(208,16,0,0.1);
      border: 1px solid rgba(208,16,0,0.35);
      border-radius: 8px;
      font-size: 0.82rem;
      color: #ff8a8a;
    }

    .gate-label {
      display: block;
      font-size: 0.77rem;
      font-weight: 600;
      color: rgba(255,255,255,0.45);
      margin-bottom: 7px;
      letter-spacing: 0.03em;
    }
    .gate-input {
      width: 100%;
      padding: 11px 14px;
      background: #0d1117;
      border: 1px solid #30363d;
      border-radius: 8px;
      color: #c9d1d9;
      font-size: 0.92rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s;
    }
    .gate-input:focus { border-color: #D01000; }
    .gate-btn {
      width: 100%;
      margin-top: 14px;
      padding: 12px;
      background: #D01000;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 0.92rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .gate-btn:hover { background: #b50d00; }
  </style>
</head>
<body>
  <div class="gate">

    <div class="gate-header">
      <img class="gate-logo" src="<%= logoUrl %>" alt="<%= appName %>">
      <div>
        <div class="gate-appname"><%= appName %></div>
        <div class="gate-company"><%= companyName %></div>
      </div>
    </div>

    <div class="gate-card">

      <div class="gate-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <div class="gate-title">Access Required</div>
      <div class="gate-sub">
        This page is restricted to <%= companyName %> staff.<br>
        Enter the access password to continue.
      </div>

      <% if (flash && flash.error) { %>
      <div class="gate-error"><%= flash.error %></div>
      <% } %>

      <form method="POST" action="/install/unlock">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="gate-label" for="password">ACCESS PASSWORD</label>
        <input
          class="gate-input"
          type="password"
          id="password"
          name="password"
          autofocus
          autocomplete="current-password"
          placeholder="••••••••"
        >
        <button class="gate-btn" type="submit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Unlock Install Page
        </button>
      </form>

    </div>
  </div>
</body>
</html>
