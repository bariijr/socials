<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/insider.css?v=1.0.1">
  <link rel="icon" href="<%= faviconUrl || '/img/favicon.ico' %>" type="image/x-icon">
  <style>
    .install-body {
      background: #0d1117;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      font-family: var(--font);
      color: var(--white);
    }

    /* ── Header ────────────────────────────────────────────────────────── */
    .install-header {
      background: var(--navy);
      border-bottom: 3px solid var(--red);
      padding: 14px 28px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .install-header-logo { width: 40px; height: 40px; border-radius: 9px; object-fit: contain; }
    .install-header-name { font-size: 1.05rem; font-weight: 700; color: var(--white); }
    .install-header-co   { font-size: 0.72rem; color: rgba(255,255,255,0.4); }

    /* ── Hero ──────────────────────────────────────────────────────────── */
    .install-hero {
      background: linear-gradient(135deg, var(--navy) 0%, #0f2340 60%, #182e4f 100%);
      padding: 52px 28px 48px;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .install-hero-logo-wrap {
      width: 88px; height: 88px;
      border-radius: 20px; overflow: hidden;
      margin: 0 auto 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 2px rgba(255,255,255,0.07);
    }
    .install-hero-logo { width: 100%; height: 100%; object-fit: contain; display: block; background: var(--navy); }
    .install-hero h1 { font-size: 1.9rem; font-weight: 800; color: var(--white); margin-bottom: 8px; line-height: 1.2; }
    .install-hero h1 span { color: var(--red); }
    .install-hero-sub { color: rgba(255,255,255,0.55); font-size: 0.95rem; max-width: 460px; margin: 0 auto; line-height: 1.65; }

    /* ── OS Tabs ───────────────────────────────────────────────────────── */
    .os-tabs-wrap {
      display: flex;
      justify-content: center;
      gap: 0;
      border-bottom: 2px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.03);
      flex-wrap: wrap;
    }
    .os-tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      font-size: 0.88rem;
      font-weight: 600;
      color: rgba(255,255,255,0.45);
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
      background: none;
      border-top: none; border-left: none; border-right: none;
      font-family: inherit;
    }
    .os-tab:hover { color: rgba(255,255,255,0.8); }
    .os-tab.active { color: var(--white); border-bottom-color: var(--red); }
    .os-tab svg { flex-shrink: 0; }

    /* ── OS Panels ─────────────────────────────────────────────────────── */
    .os-panel { display: none; }
    .os-panel.active { display: block; }

    /* ── Main content ──────────────────────────────────────────────────── */
    .install-main {
      flex: 1;
      max-width: 820px;
      margin: 0 auto;
      padding: 40px 24px 64px;
      width: 100%;
    }

    /* ── Primary action card ───────────────────────────────────────────── */
    .action-card {
      background: var(--navy);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 14px;
      padding: 28px;
      margin-bottom: 20px;
    }
    .action-card-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--red);
      margin-bottom: 10px;
    }
    .action-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 6px;
    }
    .action-card-sub {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.5);
      margin-bottom: 18px;
      line-height: 1.5;
    }

    /* One-liner command block */
    .cmd-block {
      position: relative;
      background: #0d1117;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 14px 60px 14px 16px;
      margin-bottom: 14px;
    }
    .cmd-text {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.82rem;
      color: #a8d4ff;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.6;
      user-select: all;
    }
    .cmd-copy-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 6px;
      color: rgba(255,255,255,0.6);
      padding: 5px 10px;
      font-size: 0.73rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .cmd-copy-btn:hover { background: rgba(255,255,255,0.15); color: var(--white); }
    .cmd-copy-btn.copied { background: rgba(29,185,84,0.2); color: #1DB954; border-color: #1DB954; }

    .action-card-alt {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.4);
    }
    .action-card-alt a {
      color: rgba(255,255,255,0.65);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .action-card-alt a:hover { color: var(--white); }

    /* ── Direct Downloads ──────────────────────────────────────────────── */
    .dl-section {
      margin-bottom: 24px;
    }
    .dl-section-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.3);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .dl-section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.07);
    }
    .dl-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(172px, 1fr));
      gap: 10px;
    }
    .dl-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 10px;
      text-decoration: none;
      color: var(--white);
      transition: background 0.15s, border-color 0.15s;
    }
    .dl-btn:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.18);
      color: var(--white);
    }
    .dl-btn-icon {
      flex-shrink: 0;
      width: 34px; height: 34px;
      background: rgba(208,16,0,0.12);
      border: 1px solid rgba(208,16,0,0.25);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: var(--red);
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .dl-btn-info { min-width: 0; }
    .dl-btn-label { font-size: 0.83rem; font-weight: 700; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .dl-btn-sub   { font-size: 0.7rem; color: rgba(255,255,255,0.35); }

    /* ── Steps ─────────────────────────────────────────────────────────── */
    .steps-title {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.3);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .steps-title::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.07); }
    .steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 32px; }
    .step {
      display: flex;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      flex-shrink: 0;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: rgba(208,16,0,0.12);
      border: 1.5px solid var(--red);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 700; color: var(--red);
      margin-top: 2px;
    }
    .step-body { flex: 1; }
    .step-title { font-size: 0.9rem; font-weight: 700; color: var(--white); margin-bottom: 3px; }
    .step-desc  { font-size: 0.82rem; color: rgba(255,255,255,0.5); line-height: 1.6; }
    .step-code  {
      margin-top: 8px;
      background: #0d1117;
      border: 1px solid rgba(255,255,255,0.09);
      border-left: 3px solid var(--red);
      border-radius: 7px;
      padding: 8px 12px;
      font-family: 'Consolas','Courier New',monospace;
      font-size: 0.78rem;
      color: #a8d4ff;
      white-space: pre;
      overflow-x: auto;
    }

    /* ── Connection Details Card ───────────────────────────────────────── */
    .conn-card {
      background: var(--navy);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 14px;
      padding: 24px 28px 20px;
      margin-bottom: 20px;
    }
    .conn-card-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .conn-card-head-icon {
      width: 34px; height: 34px;
      background: rgba(208,16,0,0.12);
      border: 1px solid rgba(208,16,0,0.25);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: var(--red);
      flex-shrink: 0;
    }
    .conn-card-title { font-size: 1rem; font-weight: 700; color: var(--white); }
    .conn-card-sub   { font-size: 0.81rem; color: rgba(255,255,255,0.4); margin-bottom: 18px; line-height: 1.5; }
    .conn-grid { display: flex; flex-direction: column; gap: 0; }
    .conn-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .conn-row:last-child { border-bottom: none; }
    .conn-label {
      width: 110px;
      flex-shrink: 0;
      font-size: 0.75rem;
      font-weight: 700;
      color: rgba(255,255,255,0.35);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .conn-val-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
      background: #0d1117;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 7px 8px 7px 12px;
    }
    .conn-val {
      flex: 1;
      font-family: 'Consolas','Courier New',monospace;
      font-size: 0.82rem;
      color: #a8d4ff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .conn-copy-btn {
      flex-shrink: 0;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 5px;
      color: rgba(255,255,255,0.5);
      padding: 4px 9px;
      font-size: 0.7rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .conn-copy-btn:hover { background: rgba(255,255,255,0.14); color: var(--white); }
    .conn-copy-btn.copied { background: rgba(29,185,84,0.2); color: #1DB954; border-color: #1DB954; }

    /* ── Pending notice ────────────────────────────────────────────────── */
    .pending-notice {
      background: rgba(245,166,35,0.07);
      border: 1px solid rgba(245,166,35,0.25);
      border-left: 4px solid var(--warning);
      border-radius: 10px;
      padding: 16px 20px;
      display: flex;
      gap: 14px;
      align-items: flex-start;
      margin-bottom: 20px;
    }
    .pending-notice-icon {
      flex-shrink: 0;
      width: 32px; height: 32px;
      border-radius: 50%;
      background: rgba(245,166,35,0.15);
      display: flex; align-items: center; justify-content: center;
      color: var(--warning);
    }
    .pending-notice h3 { font-size: 0.9rem; font-weight: 700; color: var(--white); margin-bottom: 3px; }
    .pending-notice p  { font-size: 0.82rem; color: rgba(255,255,255,0.5); line-height: 1.55; }

    /* ── IT Admin Deploy Section ───────────────────────────────────────── */
    .admin-deploy {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      margin-bottom: 24px;
      overflow: hidden;
    }
    .admin-deploy > summary {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 18px 22px;
      cursor: pointer;
      list-style: none;
      font-size: 0.92rem;
      font-weight: 700;
      color: rgba(255,255,255,0.7);
      user-select: none;
      transition: color 0.15s;
    }
    .admin-deploy > summary::-webkit-details-marker { display: none; }
    .admin-deploy > summary:hover { color: var(--white); }
    .admin-deploy[open] > summary { color: var(--white); border-bottom: 1px solid rgba(255,255,255,0.07); }
    .admin-deploy > summary .chevron {
      margin-left: auto;
      color: rgba(255,255,255,0.3);
      transition: transform 0.2s;
    }
    .admin-deploy[open] > summary .chevron { transform: rotate(180deg); }
    .admin-body {
      padding: 24px 22px;
    }
    .admin-section {
      margin-bottom: 26px;
    }
    .admin-section:last-child { margin-bottom: 0; }
    .admin-section-title {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--red);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 10px;
    }
    .admin-section p {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.65;
      margin-bottom: 10px;
    }
    .admin-section p:last-child { margin-bottom: 0; }
    .admin-dl-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .admin-dl-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: rgba(208,16,0,0.1);
      border: 1px solid rgba(208,16,0,0.25);
      border-radius: 8px;
      font-size: 0.8rem;
      font-weight: 600;
      color: #ff8a8a;
      text-decoration: none;
      transition: background 0.15s;
    }
    .admin-dl-link:hover { background: rgba(208,16,0,0.18); color: #fff; }
    .reg-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.78rem;
      margin-top: 10px;
    }
    .reg-table th {
      text-align: left;
      padding: 7px 10px;
      background: rgba(255,255,255,0.04);
      color: rgba(255,255,255,0.4);
      font-weight: 600;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .reg-table td {
      padding: 8px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: rgba(255,255,255,0.65);
      font-family: 'Consolas','Courier New',monospace;
      word-break: break-all;
    }
    .reg-table td:first-child { color: rgba(255,255,255,0.4); font-family: inherit; word-break: normal; }
    .reg-table tr:last-child td { border-bottom: none; }

    /* ── Footer ────────────────────────────────────────────────────────── */
    .install-footer {
      background: var(--navy);
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 16px 28px;
      text-align: center;
      font-size: 0.73rem;
      color: rgba(255,255,255,0.25);
    }

    @media (max-width: 600px) {
      .install-hero { padding: 36px 16px 32px; }
      .install-hero h1 { font-size: 1.5rem; }
      .install-main { padding: 28px 16px 48px; }
      .os-tab { padding: 12px 14px; font-size: 0.8rem; }
      .action-card { padding: 20px 16px; }
      .conn-label { width: 80px; }
      .dl-grid { grid-template-columns: 1fr 1fr; }
      .admin-body { padding: 18px 16px; }
    }
  </style>
</head>
<body class="install-body">

  <!-- Header -->
  <header class="install-header">
    <img src="<%= logoUrl %>" alt="<%= appName %>" class="install-header-logo">
    <div>
      <div class="install-header-name"><%= appName %></div>
      <div class="install-header-co"><%= companyName %></div>
    </div>
  </header>

  <!-- Hero -->
  <div class="install-hero">
    <div class="install-hero-logo-wrap">
      <img src="<%= logoUrl %>" alt="<%= appName %>" class="install-hero-logo">
    </div>
    <h1>Connect to <span><%= companyName %></span></h1>
    <p class="install-hero-sub">
      Install the <%= appName %> client to allow our technicians to securely access your device.
      Choose your operating system below — setup is automatic.
    </p>
  </div>

  <!-- OS Tab bar -->
  <div class="os-tabs-wrap" id="osTabs">
    <button class="os-tab" id="tab-windows" onclick="selectOs('windows')">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M3 12V6.75l6-1.02V12H3zm0 6.75L9 19.8V13H3v5.75zm7.5-1.92 7.5 1.07V13h-7.5v4.83zm0-10.64V12h7.5V5.16l-7.5 1.03z"/>
      </svg>
      Windows
    </button>
    <button class="os-tab" id="tab-linux" onclick="selectOs('linux')">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M12.5 2C9.48 2 7 4.48 7 7.5c0 1.74.81 3.28 2.07 4.3-.5.86-.8 1.9-.8 3C8.27 17.07 10.06 19 12.25 19c1.2 0 2.28-.52 3.04-1.36C15.9 17.2 16.5 16.2 16.5 15c0-1.03-.3-1.98-.79-2.77A5.49 5.49 0 0 0 18 7.5C18 4.48 15.52 2 12.5 2zM9 21h6l-1-2h-4L9 21z"/>
      </svg>
      Linux
    </button>
    <button class="os-tab" id="tab-mac" onclick="selectOs('mac')">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      macOS
    </button>
    <button class="os-tab" id="tab-android" onclick="selectOs('android')">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M17.6 9.48l1.84-3.18c.16-.31.04-.69-.26-.85-.29-.15-.65-.06-.83.22l-1.88 3.24C14.9 8.13 13.5 7.75 12 7.75c-1.5 0-2.9.38-4.14.97L5.98 5.48c-.18-.29-.54-.37-.83-.22-.3.16-.42.54-.26.85L6.74 9.48C4.1 11.02 2.5 13.8 2.5 17h19c0-3.2-1.6-5.98-3.9-7.52zM9 14c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm6 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
      </svg>
      Android
    </button>
  </div>

  <!-- Main content -->
  <main class="install-main">

    <!-- ══ WINDOWS ══════════════════════════════════════════════════════════ -->
    <div class="os-panel" id="panel-windows">

      <div class="action-card">
        <div class="action-card-label">Quickest — paste in any PowerShell window</div>
        <div class="action-card-title">One-Click Install</div>
        <div class="action-card-sub">
          Open PowerShell (no admin needed) and paste the command below.
          Windows will show a security prompt — click <strong>Yes</strong>.
          A branded setup window walks you through the rest.
        </div>
        <div class="cmd-block">
          <div class="cmd-text" id="win-oneliner">irm '<%= apiBase %>/install/download/windows.ps1' -OutFile "$env:TEMP\ir.ps1"; Start-Process powershell -Verb RunAs -ArgumentList "-NoP -EP Bypass -WindowStyle Hidden -File $env:TEMP\ir.ps1"</div>
          <button class="cmd-copy-btn" id="win-copy-btn" onclick="copyCmd('win-oneliner','win-copy-btn')">Copy</button>
        </div>
        <div class="action-card-alt">
          Prefer to inspect first?
          <a href="/install/download/windows.ps1" download="InsiderRemote-Setup.ps1">Download InsiderRemote-Setup.ps1</a>
          &nbsp;&bull;&nbsp;
          <a href="/install/download/windows.bat" download="InsiderRemote-Setup.bat">Download .bat launcher</a>
        </div>
      </div>

      <div class="dl-section">
        <div class="dl-section-label">Or download v<%= rdVer %> directly</div>
        <div class="dl-grid">
          <a class="dl-btn" href="https://github.com/rustdesk/rustdesk/releases/download/<%= rdVer %>/rustdesk-<%= rdVer %>-x86_64.exe" target="_blank" rel="noopener">
            <div class="dl-btn-icon">EXE</div>
            <div class="dl-btn-info">
              <div class="dl-btn-label">Windows x64</div>
              <div class="dl-btn-sub">Installer · 64-bit</div>
            </div>
          </a>
