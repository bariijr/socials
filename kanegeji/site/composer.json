{
    "name": "kanegeji/parish-erp",
    "description": "Kanegeji Parish ERP System",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.1",
        "phpoffice/phpword": "^1.2",
        "phpmailer/phpmailer": "^6.9",
        "chillerlan/php-qrcode": "^5.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "app/Core/",
            "App\\Config\\": "config/",
            "App\\Helpers\\": "app/Helpers/",
            "App\\Modules\\Auth\\": "modules/Auth/",
            "App\\Modules\\Dashboard\\": "modules/Dashboard/",
            "App\\Modules\\Members\\": "modules/Members/",
            "App\\Modules\\Jumuiya\\": "modules/Jumuiya/",
            "App\\Modules\\Accounting\\": "modules/Accounting/",
            "App\\Modules\\Reports\\": "modules/Reports/",
            "App\\Modules\\Audit\\": "modules/Audit/",
            "App\\Modules\\Settings\\": "modules/Settings/",
            "App\\Modules\\Users\\": "modules/Users/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
