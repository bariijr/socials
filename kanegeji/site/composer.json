{
    "name": "kanegeji/parish-erp",
    "description": "Kanegeji Parish ERP System",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "mpdf/mpdf": "^8.2",
        "minishlink/web-push": "^9.0",
        "phpoffice/phpspreadsheet": "^2.1",
        "phpoffice/phpword": "^1.2",
        "phpmailer/phpmailer": "^6.9",
        "chillerlan/php-qrcode": "^5.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "app/Core/",
            "App\\Config\\": "config/",
            "App\\Helpers\\": "app/Helpers/",
            "App\\Modules\\Auth\\": "modules/Auth/",
            "App\\Modules\\Dashboard\\": "modules/Dashboard/",
            "App\\Modules\\Members\\": "modules/Members/",
            "App\\Modules\\Jumuiya\\": "modules/Jumuiya/",
            "App\\Modules\\Accounting\\": "modules/Accounting/",
            "App\\Modules\\Reports\\": "modules/Reports/",
            "App\\Modules\\Audit\\": "modules/Audit/",
            "App\\Modules\\Settings\\": "modules/Settings/",
            "App\\Modules\\Users\\": "modules/Users/",
            "App\\Modules\\Payroll\\": "modules/Payroll/",
            "App\\Modules\\Inventory\\": "modules/Inventory/",
            "App\\Modules\\Documents\\": "modules/Documents/",
            "App\\Modules\\Events\\": "modules/Events/",
            "App\\Modules\\Bookings\\": "modules/Bookings/",
            "App\\Modules\\Families\\": "modules/Families/",
            "App\\Modules\\Sacraments\\": "modules/Sacraments/",
            "App\\Modules\\Pledges\\": "modules/Pledges/",
            "App\\Modules\\Reconciliation\\": "modules/Reconciliation/",
            "App\\Modules\\Notifications\\": "modules/Notifications/",
            "App\\Modules\\Admin\\": "modules/Admin/",
            "App\\Modules\\AI\\": "modules/AI/",
            "App\\Modules\\Budget\\": "modules/Budget/",
            "App\\Modules\\Announcements\\": "modules/Announcements/",
            "App\\Modules\\MassSchedules\\": "modules/MassSchedules/",
            "App\\Modules\\AIKnowledge\\": "modules/AIKnowledge/",
            "App\\Modules\\Catholic\\": "modules/Catholic/",
            "App\\Modules\\Website\\": "modules/Website/",
            "App\\Modules\\Portal\\": "modules/Portal/",
            "App\\Modules\\Search\\": "modules/Search/",
            "App\\Modules\\Payments\\": "modules/Payments/",
            "App\\Modules\\Committees\\": "modules/Committees/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
