# ============================================================
# KANEGEJI PARISH ERP — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

APP_NAME="Parokia ya Kanegeji"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://kanegeji.go.tz
APP_KEY=change_this_to_a_random_64_char_string
APP_TIMEZONE=Africa/Dar_es_Salaam
APP_LOCALE=sw

# ============================================================
# DATABASE
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kanegeji_erp
DB_USER=kanegeji_user
DB_PASS=strong_password_here
DB_CHARSET=utf8mb4

# ============================================================
# SESSION
# ============================================================
SESSION_NAME=kanegeji_sess
SESSION_LIFETIME=7200
SESSION_SECURE=true
SESSION_HTTPONLY=true

# ============================================================
# SECURITY
# ============================================================
CSRF_TOKEN_NAME=_csrf_token
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=900

# ============================================================
# MAIL (SMTP)
# ============================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=notifications@kanegeji.go.tz
MAIL_PASSWORD=app_specific_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Parokia ya Kanegeji"
MAIL_FROM_ADDRESS=no-reply@kanegeji.go.tz

# ============================================================
# SMS (Beem Africa — https://beemafrica.com)
# WhatsApp is attempted first for transactional messages;
# SMS (Beem) is the automatic fallback when WhatsApp fails.
# ============================================================
BEEM_API_KEY=your_beem_api_key
BEEM_SECRET_KEY=your_beem_secret_key
BEEM_SENDER_ID=KANEGEJI

# ============================================================
# WHATSAPP — set WA_PROVIDER to one of: evolution | whatchamp | twilio
# ============================================================
WA_PROVIDER=evolution

# -- Option 1: Evolution API (self-hosted, recommended) ------
# https://doc.evolution-api.com
WA_EVOLUTION_URL=https://your-evolution-server.com
WA_EVOLUTION_INSTANCE=kanegeji
WA_EVOLUTION_API_KEY=your_evolution_api_key

# -- Option 2: WhatChimp ------------------------------------
# Verify endpoint + response format in your WhatChimp dashboard.
WA_WHATCHAMP_URL=https://api.whatchamp.com/v1
WA_WHATCHAMP_API_KEY=your_whatchamp_api_key

# -- Option 3: Twilio (legacy / fallback) -------------------
# Twilio scheduled sends not supported via this integration.
WA_ACCOUNT_SID=your_twilio_account_sid
WA_AUTH_TOKEN=your_twilio_auth_token
WA_FROM=+1415XXXXXXX

# ============================================================
# AI (OpenAI)
# ============================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# ============================================================
# BACKUP
# ============================================================
BACKUP_EMAIL=admin@kanegeji.go.tz
BACKUP_GOOGLE_DRIVE=false
BACKUP_DROPBOX=false
BACKUP_RETENTION_DAYS=30

# ============================================================
# UPLOADS
# ============================================================
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx

# ============================================================
# AZAM PAY (Tanzania mobile money — https://azampay.co.tz)
# WA_ENV: sandbox | production
# ============================================================
AZAM_ENV=sandbox
AZAM_APP_NAME=KanegejiERP
AZAM_CLIENT_ID=your_azam_client_id
AZAM_CLIENT_SECRET=your_azam_client_secret
AZAM_SANDBOX_AUTH_URL=https://authenticator.sandbox.azampay.co.tz
AZAM_SANDBOX_API_URL=https://sandbox.azampay.co.tz
AZAM_PROD_AUTH_URL=https://authenticator.azampay.co.tz
AZAM_PROD_API_URL=https://api.azampay.co.tz
AZAM_CALLBACK_URL=https://kanegeji.go.tz/pay/callback

# ============================================================
# WEB PUSH (VAPID keys — generate once with make vapid-keys)
# php -r "
#   \$kp = \Minishlink\WebPush\VAPID::createVapidKeys();
#   echo 'VAPID_PUBLIC_KEY='.\$kp['publicKey'].PHP_EOL;
#   echo 'VAPID_PRIVATE_KEY='.\$kp['privateKey'].PHP_EOL;
# "
# ============================================================
VAPID_PUBLIC_KEY=your_base64url_public_key
VAPID_PRIVATE_KEY=your_base64url_private_key

# ============================================================
# PARISH
# ============================================================
PARISH_ID=1
PARISH_NAME="Parokia ya Kanegeji"
PARISH_CURRENCY=TZS
